---
import '../styles/tokens.css';
import '../styles/prose.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'kb.duyet.net', description = 'Duyet Le — shared knowledge base' } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f7fbfd" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c0e10" media="(prefers-color-scheme: dark)" />
    <link rel="alternate" type="application/rss+xml" title="kb.duyet.net RSS" href={`${base}/rss.xml`} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <!-- Prevent FOUC: run theme init before paint -->
    <script is:inline>
      (function () {
        try {
          var d = localStorage.getItem('theme') ||
            (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', d);
          document.documentElement.classList.add('no-transitions');
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              document.documentElement.classList.remove('no-transitions');
            });
          });
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="site-header">
      <nav class="site-nav">
        <a href={`${base}/`} class="logo" aria-label="kb.duyet.net home">
          <span class="logo-mark" aria-hidden="true">◆</span>
          <span class="logo-label">kb</span>
        </a>
        <div class="nav-links">
          <a href={`${base}/`} class:list={['nav-link', { active: currentPath === `${base}/` || currentPath === base || currentPath === `${base}` }]}>Home</a>
          <a href={`${base}/memory`} class:list={['nav-link', { active: currentPath.includes('/memory') }]}>Memory</a>
          <a href={`${base}/articles`} class:list={['nav-link', { active: currentPath.includes('/articles') }]}>Articles</a>
        </div>
        <button class="search-toggle" id="search-toggle" aria-label="Search site" title="Search (/)">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle color theme" title="Toggle dark/light mode">
          <span class="theme-icon theme-icon--sun" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </span>
          <span class="theme-icon theme-icon--moon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </span>
        </button>
      </nav>
    </header>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-text">
          <a href="https://github.com/duyet/kb" target="_blank" rel="noopener">GitHub</a> ·
          <a href={`${base}/rss.xml`}>RSS</a> ·
          <a href={`${base}/llms.txt`}>llms.txt</a> ·
          <a href={`${base}/llms-full.txt`}>llms-full.txt</a>
        </p>
        <p class="footer-text muted">
          Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · Inspired by <a href="https://github.com/hanityx/astro-tone" target="_blank" rel="noopener">astro-tone</a>
        </p>
      </div>
    </footer>

    <script>
      // Theme toggle
      const btn = document.getElementById('theme-toggle');
      const html = document.documentElement;

      function getTheme() {
        try { return localStorage.getItem('theme'); } catch { return null; }
      }

      function setTheme(theme: string) {
        html.setAttribute('data-theme', theme);
        try { localStorage.setItem('theme', theme); } catch {}
      }

      function resolvedTheme() {
        return getTheme() || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      }

      btn?.addEventListener('click', () => {
        setTheme(resolvedTheme() === 'dark' ? 'light' : 'dark');
      });
    </script>

    <!-- Search Modal -->
    <div class="search-overlay" id="search-overlay" aria-hidden="true" role="dialog" aria-modal="true">
      <div class="search-dialog" id="search-dialog">
        <div class="search-header">
          <svg class="search-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input type="search" id="search-input" placeholder="Search notes and articles..." autocomplete="off" spellcheck="false" />
          <button class="search-close-btn" id="search-close" aria-label="Close search">Esc</button>
        </div>
        <div class="search-results-wrap">
          <div class="search-status" id="search-status">Type to search...</div>
          <div class="search-results-list" id="search-results"></div>
        </div>
        <div class="search-footer">
          <span class="search-hint"><kbd>↑↓</kbd> Navigate</span>
          <span class="search-hint"><kbd>Enter</kbd> Select</span>
          <span class="search-hint"><kbd>Esc</kbd> Close</span>
        </div>
      </div>
    </div>

    <script define:vars={{ base }}>
      // Search functionality
      const searchToggle = document.getElementById('search-toggle');
      const searchOverlay = document.getElementById('search-overlay');
      const searchDialog = document.getElementById('search-dialog');
      const searchInput = document.getElementById('search-input');
      const searchClose = document.getElementById('search-close');
      const searchResults = document.getElementById('search-results');
      const searchStatus = document.getElementById('search-status');

      let searchIndex = null;
      let selectedIndex = -1;
      let currentItems = [];

      async function ensureSearchIndex() {
        if (searchIndex !== null) return;
        searchStatus.textContent = 'Loading index...';
        try {
          const res = await fetch(`${base}/search-index.json`);
          searchIndex = await res.json();
          searchStatus.textContent = 'Type to search...';
        } catch (err) {
          searchStatus.textContent = 'Failed to load search index.';
          console.error(err);
        }
      }

      function openSearch() {
        searchOverlay.classList.add('active');
        document.body.style.overflow = 'hidden';
        searchInput.focus();
        ensureSearchIndex();
      }

      function closeSearch() {
        searchOverlay.classList.remove('active');
        document.body.style.overflow = '';
        searchInput.value = '';
        searchResults.innerHTML = '';
        searchStatus.style.display = 'block';
        searchStatus.textContent = 'Type to search...';
        selectedIndex = -1;
        currentItems = [];
      }

      function highlight(text, query) {
        if (!query) return text;
        const q = query.toLowerCase();
        const index = text.toLowerCase().indexOf(q);
        if (index === -1) return text;
        return text.substring(0, index) + '<mark>' + text.substring(index, index + query.length) + '</mark>' + text.substring(index + query.length);
      }

      function getBodySnippet(body, query) {
        if (!body || !query) return '';
        const q = query.toLowerCase();
        const bodyLower = body.toLowerCase();
        const index = bodyLower.indexOf(q);
        if (index === -1) return body.substring(0, 100) + '...';
        
        const start = Math.max(0, index - 40);
        const end = Math.min(body.length, index + query.length + 60);
        let snippet = body.substring(start, end);
        if (start > 0) snippet = '...' + snippet;
        if (end < body.length) snippet = snippet + '...';
        return highlight(snippet, query);
      }

      function performSearch() {
        const query = searchInput.value.trim();
        if (!query) {
          searchResults.innerHTML = '';
          searchStatus.style.display = 'block';
          searchStatus.textContent = 'Type to search...';
          selectedIndex = -1;
          currentItems = [];
          return;
        }

        if (!searchIndex) return;

        const q = query.toLowerCase();
        const results = searchIndex.map(item => {
          let score = 0;
          const titleL = item.title.toLowerCase();
          const descL = item.description ? item.description.toLowerCase() : '';
          const bodyL = item.body.toLowerCase();
          
          if (titleL === q) score += 100;
          else if (titleL.startsWith(q)) score += 80;
          else if (titleL.includes(q)) score += 50;

          if (descL.includes(q)) score += 20;
          if (bodyL.includes(q)) score += 5;

          item.tags.forEach(t => {
            const tl = t.toLowerCase();
            if (tl === q) score += 30;
            else if (tl.includes(q)) score += 10;
          });

          return { ...item, score };
        })
        .filter(item => item.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 10);

        currentItems = results;
        selectedIndex = -1;

        if (results.length === 0) {
          searchResults.innerHTML = '';
          searchStatus.style.display = 'block';
          searchStatus.textContent = 'No results found.';
          return;
        }

        searchStatus.style.display = 'none';
        searchResults.innerHTML = results.map((item, idx) => {
          const titleHtml = highlight(item.title, query);
          let snippet = '';
          if (item.description && item.description.toLowerCase().includes(q)) {
            snippet = highlight(item.description, query);
          } else {
            snippet = getBodySnippet(item.body, query);
          }

          return `
            <a href="${item.url}" class="search-item" data-index="${idx}">
              <div class="search-item-meta">
                <span class="search-item-type">${item.type}</span>
                <span class="search-item-category">${item.category}</span>
              </div>
              <div class="search-item-title">${titleHtml}</div>
              <div class="search-item-snippet">${snippet}</div>
            </a>
          `;
        }).join('');
      }

      function updateSelection() {
        const items = searchResults.querySelectorAll('.search-item');
        items.forEach((item, idx) => {
          if (idx === selectedIndex) {
            item.classList.add('selected');
            item.scrollIntoView({ block: 'nearest' });
          } else {
            item.classList.remove('selected');
          }
        });
      }

      // Event Listeners
      searchToggle?.addEventListener('click', openSearch);
      searchClose?.addEventListener('click', closeSearch);
      searchOverlay?.addEventListener('click', (e) => {
        if (e.target === searchOverlay) closeSearch();
      });

      searchInput?.addEventListener('input', performSearch);

      window.addEventListener('keydown', (e) => {
        // Press / to open, but ignore if inside inputs/textareas
        if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
          e.preventDefault();
          openSearch();
        }

        if (!searchOverlay?.classList.contains('active')) return;

        if (e.key === 'Escape') {
          closeSearch();
        } else if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (currentItems.length > 0) {
            selectedIndex = (selectedIndex + 1) % currentItems.length;
            updateSelection();
          }
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (currentItems.length > 0) {
            selectedIndex = (selectedIndex - 1 + currentItems.length) % currentItems.length;
            updateSelection();
          }
        } else if (e.key === 'Enter') {
          if (selectedIndex >= 0 && selectedIndex < currentItems.length) {
            e.preventDefault();
            window.location.href = currentItems[selectedIndex].url;
          }
        }
      });

      // Handle hover trigger selection index sync
      searchResults?.addEventListener('mouseover', (e) => {
        const item = e.target.closest('.search-item');
        if (item) {
          selectedIndex = parseInt(item.getAttribute('data-index') || '-1', 10);
          updateSelection();
        }
      });
    </script>
  </body>
</html>

<style>
  /* Skip link */
  .skip-link {
    position: fixed;
    top: 0;
    left: var(--space-4);
    z-index: 9999;
    padding: var(--space-2) var(--space-5);
    background: var(--color-accent);
    color: #fff;
    font-size: var(--text-footnote);
    font-weight: 600;
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    text-decoration: none;
    transform: translateY(calc(-100% - var(--space-2)));
    transition: transform 150ms ease-out;
  }

  .skip-link:focus {
    outline: 2px solid #fff;
    outline-offset: 2px;
    transform: translateY(0);
  }

  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    background: color-mix(in srgb, var(--bg-primary) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid color-mix(in srgb, var(--separator) 60%, transparent);
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .site-nav {
    width: 100%;
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--label-primary);
    font-weight: var(--weight-semibold);
    font-size: var(--text-callout);
    letter-spacing: var(--tracking-tight);
    transition: opacity var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
  }

  .logo:hover { opacity: 0.75; }

  .logo-mark {
    font-size: 0.85em;
    color: var(--color-accent);
    line-height: 1;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex: 1;
  }

  .nav-link {
    font-size: var(--text-subheadline);
    font-weight: var(--weight-medium);
    color: var(--label-tertiary);
    padding: 5px var(--space-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--label-primary);
    background: var(--fill-tertiary);
    opacity: 1;
  }

  .nav-link.active {
    color: var(--label-primary);
    font-weight: var(--weight-semibold);
  }

  /* Theme toggle button */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--label-tertiary);
    cursor: pointer;
    border-radius: var(--radius-sm);
    padding: 0;
    transition:
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    color: var(--label-primary);
    background: var(--fill-tertiary);
  }

  /* Show sun in dark mode, moon in light mode */
  .theme-icon--sun { display: none; }
  .theme-icon--moon { display: flex; }

  [data-theme="dark"] .theme-icon--sun { display: flex; }
  [data-theme="dark"] .theme-icon--moon { display: none; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .theme-icon--sun { display: flex; }
    :root:not([data-theme="light"]) .theme-icon--moon { display: none; }
  }

  /* Main content */
  main {
    width: 100%;
    min-height: calc(100dvh - var(--nav-height) - 120px);
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid color-mix(in srgb, var(--separator) 50%, transparent);
    padding: var(--space-8) var(--space-6);
    background: var(--bg-secondary);
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .footer-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer-text {
    margin: 0;
    font-size: var(--text-footnote);
    color: var(--label-secondary);
  }

  .footer-text.muted {
    color: var(--label-tertiary);
  }

  .footer-text a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 2px;
    transition:
      color var(--duration-fast) var(--ease-out),
      text-decoration-color var(--duration-fast) var(--ease-out);
  }

  .footer-text a:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
    opacity: 1;
  }

  /* Search toggle button */
  .search-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--label-tertiary);
    cursor: pointer;
    border-radius: var(--radius-sm);
    padding: 0;
    margin-right: var(--space-1);
    transition:
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
  }

  .search-toggle:hover {
    color: var(--label-primary);
    background: var(--fill-tertiary);
  }

  /* Search Overlay & Dialog */
  .search-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 12vh var(--space-4) var(--space-4);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .search-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  .search-dialog {
    background: var(--bg-primary);
    width: 100%;
    max-width: 580px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--separator);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform: translateY(-12px);
    transition: transform var(--duration-normal) var(--ease-spring);
  }

  .search-overlay.active .search-dialog {
    transform: translateY(0);
  }

  .search-header {
    display: flex;
    align-items: center;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--separator);
    gap: var(--space-3);
  }

  .search-input-icon {
    color: var(--label-tertiary);
    flex-shrink: 0;
  }

  #search-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--label-primary);
    font-size: var(--text-headline);
    font-family: var(--font-sans);
    outline: none;
    padding: 0;
  }

  #search-input::-webkit-search-cancel-button {
    display: none;
  }

  .search-close-btn {
    font-size: var(--text-caption-1);
    font-family: var(--font-sans);
    color: var(--label-tertiary);
    background: var(--fill-tertiary);
    border: 1px solid var(--separator);
    padding: 3px 6px;
    border-radius: var(--radius-xs);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .search-close-btn:hover {
    color: var(--label-primary);
    background: var(--fill-secondary);
  }

  .search-results-wrap {
    max-height: 380px;
    overflow-y: auto;
    background: var(--bg-primary);
  }

  .search-status {
    padding: var(--space-6) var(--space-5);
    text-align: center;
    font-size: var(--text-subheadline);
    color: var(--label-tertiary);
  }

  .search-results-list {
    display: flex;
    flex-direction: column;
    padding: var(--space-2);
  }

  .search-item {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 2px;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .search-item.selected {
    background: var(--fill-tertiary);
  }

  .search-item-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .search-item-type {
    font-size: var(--text-caption-2);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .search-item-category {
    font-size: var(--text-caption-2);
    color: var(--label-quaternary);
  }

  .search-item-title {
    font-size: var(--text-subheadline);
    font-weight: var(--weight-semibold);
    color: var(--label-primary);
  }

  .search-item-snippet {
    font-size: var(--text-footnote);
    color: var(--label-tertiary);
    line-height: var(--leading-normal);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-item-snippet mark {
    background: color-mix(in srgb, var(--color-accent) 25%, transparent);
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }

  .search-item-title mark {
    background: color-mix(in srgb, var(--color-accent) 25%, transparent);
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }

  .search-footer {
    padding: var(--space-3) var(--space-5);
    border-top: 1px solid var(--separator);
    background: var(--bg-secondary);
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-caption-2);
    color: var(--label-quaternary);
  }

  .search-hint {
    display: flex;
    align-items: center;
    gap: 4px;

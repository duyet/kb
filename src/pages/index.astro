---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const notes = await getCollection('memory');
const articles = await getCollection('articles');

const notesSorted = notes.sort((a, b) => String(a.data.name).localeCompare(String(b.data.name)));
const articlesSorted = articles.sort((a, b) => {
  // Sort articles by updated desc, fallback to title
  const da = String(a.data.updated || '');
  const db = String(b.data.updated || '');
  return db.localeCompare(da) || String(a.data.title).localeCompare(String(b.data.title));
});

// Show recent 8 articles on home, link to /articles for full list
const recentArticles = articlesSorted.slice(0, 8);
---

<Layout
  title="kb.duyet.net — shared brain"
  description="A single, plain-text knowledge base and shared brain read and written by AI coding agents, automated for Duyet Le."
>
  <div class="page-wrap">
    <section class="hero">
      <p class="hero-eyebrow">Shared brain</p>
      <h1 class="hero-title">Keep notes.</h1>
      <p class="hero-desc">
        A plain-text knowledge base that AI coding agents read from and write to. 
        Reconstructed and maintained automatically by AI for <a href="https://duyet.net" target="_blank" rel="noopener">Duyet Le</a>.
      </p>
    </section>

    <div class="page-divider"></div>

    <section class="content-section">
      <div class="section-header">
        <h2 class="section-title">Memory</h2>
        <span class="section-count">{notesSorted.length} notes</span>
      </div>
      <ul class="item-list">
        {notesSorted.map(n => (
          <li class="item">
            <a href={`${base}/memory/${n.slug}`} class="item-link">
              <span class="item-title">{n.data.title || n.data.name}</span>
              <span class="item-arrow">→</span>
            </a>
            <span class="item-desc">{n.data.description}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="content-section">
      <div class="section-header">
        <h2 class="section-title">Articles</h2>
        <a href={`${base}/articles`} class="section-link">View all {articles.length} →</a>
      </div>
      <ul class="item-list">
        {recentArticles.map(a => (
          <li class="item">
            <a href={`${base}/articles/${a.slug}`} class="item-link">
              <span class="item-title">{a.data.title}</span>
              <span class="item-arrow">→</span>
            </a>
            {a.data.summary && <span class="item-desc">{a.data.summary}</span>}
          </li>
        ))}
      </ul>
      {articles.length > 8 && (
        <a href={`${base}/articles`} class="view-all-link">
          View all {articles.length} articles →
        </a>
      )}
    </section>
  </div>
</Layout>

<style>
  .page-wrap {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-24);
  }

  /* Hero */
  .hero {
    padding-bottom: var(--space-10);
  }

  .hero-eyebrow {
    font-size: var(--text-caption-1);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 var(--space-4);
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.0;
    margin: 0 0 var(--space-5);
    color: var(--label-primary);
  }

  .hero-desc {
    font-size: var(--text-title-3);
    color: var(--label-secondary);
    margin: 0;
    line-height: var(--leading-snug);
    max-width: 480px;
  }

  .hero-desc a {
    color: var(--label-primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--separator) 80%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--duration-fast) var(--ease-out);
  }

  .hero-desc a:hover {
    text-decoration-color: var(--label-primary);
    opacity: 1;
  }

  .page-divider {
    height: 1px;
    background: var(--separator);
    margin-bottom: var(--space-12);
  }

  /* Sections */
  .content-section {
    margin-top: var(--space-12);
  }

  .content-section + .content-section {
    margin-top: var(--space-16);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .section-title {
    font-size: var(--text-callout);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--label-tertiary);
    margin: 0;
  }

  .section-count {
    font-size: var(--text-footnote);
    color: var(--label-quaternary);
    font-variant-numeric: tabular-nums;
  }

  .section-link {
    font-size: var(--text-footnote);
    font-weight: var(--weight-medium);
    color: var(--color-accent);
    margin-left: auto;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .section-link:hover { opacity: 0.75; }

  /* Item list */
  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .item {
    padding: var(--space-4) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    border-bottom: 1px solid color-mix(in srgb, var(--separator) 35%, transparent);
  }

  .item:first-child {
    border-top: 1px solid color-mix(in srgb, var(--separator) 35%, transparent);
  }

  .item-link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    color: var(--label-primary);
    text-decoration: none;
    font-size: var(--text-callout);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .item-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .item-title {
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    transition: text-decoration-color var(--duration-fast) var(--ease-out);
  }

  .item-link:hover .item-title {
    text-decoration-color: currentColor;
  }

  .item-arrow {
    color: var(--label-quaternary);
    font-size: 0.85em;
    transition:
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .item-link:hover .item-arrow {
    color: var(--color-accent);
    transform: translateX(2px);
  }

  .item-desc {
    font-size: var(--text-footnote);
    color: var(--label-tertiary);
    line-height: var(--leading-normal);
  }

  /* View all link */
  .view-all-link {
    display: inline-block;
    margin-top: var(--space-6);
    font-size: var(--text-subheadline);
    font-weight: var(--weight-medium);
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .view-all-link:hover { opacity: 0.75; }

  @media (max-width: 600px) {
    .page-wrap {
      padding: var(--space-10) var(--space-4) var(--space-16);
    }

    .hero-title {
      font-size: 2.25rem;
    }

    .hero-desc {
      font-size: var(--text-callout);
    }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({ params: { slug: article.slug }, props: { article } }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function fmtDate(d: string | Date | undefined) {
  if (!d) return '';
  const str = String(d);
  if (/^\d{4}-\d{2}-\d{2}/.test(str)) {
    const [y, m, day] = str.split('-');
    return new Date(Number(y), Number(m) - 1, Number(day))
      .toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' });
  }
  return str;
}
---

<Layout title={`${article.data.title} — kb`} description={article.data.summary}>
  <div class="post-main">
    <a href={`${base}/articles`} class="back-link">← Articles</a>

    <header class="post-header">
      <div class="post-accent"></div>
      <div class="post-meta">
        {article.data.category && <span class="meta-tag">{article.data.category}</span>}
        {article.data.category && article.data.updated && <span class="meta-dot">·</span>}
        {article.data.updated && <span class="meta-date">{fmtDate(article.data.updated)}</span>}
      </div>
      <h1 class="post-title">{article.data.title}</h1>
      {article.data.summary && (
        <p class="post-description">{article.data.summary}</p>
      )}
    </header>

    <div class="post-divider"></div>

    <div class="prose">
      <Content />
    </div>

    <div class="post-footer-meta">
      {article.data.tags && article.data.tags.length > 0 && (
        <div class="footer-block">
          <p class="footer-label">Tags</p>
          <div class="tag-list">
            {article.data.tags.map(t => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </div>
      )}

      {article.data.links && article.data.links.length > 0 && (
        <div class="footer-block">
          <p class="footer-label">Related</p>
          <div class="tag-list">
            {article.data.links.map(l => (
              <span class="tag tag--muted">{l.replace(/^\[\[|\]\]$/g, '')}</span>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .post-main {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-10) var(--space-6) var(--space-24);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-footnote);
    font-weight: var(--weight-medium);
    color: var(--label-tertiary);
    text-decoration: none;
    margin-bottom: var(--space-10);
    letter-spacing: 0.01em;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .back-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .post-accent {
    width: 28px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 99px;
    margin-bottom: var(--space-6);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-footnote);
    color: var(--label-tertiary);
    margin-bottom: var(--space-5);
    font-variant-numeric: tabular-nums;
  }

  .meta-tag {
    font-size: var(--text-caption-1);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .meta-dot {
    color: var(--label-quaternary);
  }

  .meta-date {
    color: var(--label-tertiary);
  }

  .post-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0 0 var(--space-5);
    color: var(--label-primary);
  }

  .post-description {
    font-size: var(--text-callout);
    color: var(--label-secondary);
    font-weight: 400;
    line-height: 1.64;
    margin: 0;
    max-width: 520px;
    border-left: 2px solid var(--separator);
    padding-left: var(--space-4);
  }

  .post-divider {
    height: 1px;
    background: var(--separator);
    margin: var(--space-8) 0 var(--space-10);
  }

  .post-footer-meta {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid color-mix(in srgb, var(--separator) 50%, transparent);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-label {
    margin: 0;
    font-size: var(--text-caption-1);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--label-quaternary);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    font-size: var(--text-footnote);
    font-weight: var(--weight-medium);
    color: var(--color-accent);
    background: var(--fill-secondary);
    padding: 0.18em 0.6em;
    border-radius: 99px;
  }

  .tag--muted {
    color: var(--label-secondary);
    background: var(--fill-tertiary);
  }

  @media (max-width: 600px) {
    .post-main {
      padding: var(--space-8) var(--space-4) var(--space-16);
    }

    .post-title {
      font-size: 1.75rem;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import KnowledgeGraph from '../components/KnowledgeGraph.astro';
---

<Layout
  title="Knowledge Graph — kb.duyet.net"
  description="An interactive 3D graph of the knowledge base — notes and articles connected by links and shared tags."
>
  <div class="graph-page">
    <KnowledgeGraph />
  </div>
</Layout>

<style>
  .graph-page {
    position: relative;
    width: 100%;
    /* fill the viewport below the nav, leaving a little bottom clearance */
    --kgraph-height: calc(100svh - var(--nav-height) - var(--space-12));
  }

</style>

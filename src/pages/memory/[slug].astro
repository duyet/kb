---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('memory');
  return notes.map(note => ({ params: { slug: note.slug }, props: { note } }));
}

const { note } = Astro.props;
const { Content } = await note.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Format date nicely
function fmtDate(d: string | Date | undefined) {
  if (!d) return '';
  const str = String(d);
  if (/^\d{4}-\d{2}-\d{2}/.test(str)) {
    const [y, m, day] = str.split('-');
    return new Date(Number(y), Number(m) - 1, Number(day))
      .toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' });
  }
  return str;
}
---

<Layout title={`${note.data.title || note.data.name} — kb`} description={note.data.description}>
  <div class="post-main">
    <a href={`${base}/memory`} class="back-link">← Memory</a>

    <header class="post-header">
      <div class="post-accent"></div>
      <div class="post-meta">
        {note.data.type && <span class="meta-tag">{note.data.type}</span>}
        {note.data.type && note.data.updated && <span class="meta-dot">·</span>}
        {note.data.updated && <span class="meta-date">{fmtDate(note.data.updated)}</span>}
      </div>
      <h1 class="post-title">{note.data.title || note.data.name}</h1>
      <p class="post-description">{note.data.description}</p>
    </header>

    <div class="post-divider"></div>

    <div class="prose">
      <Content />
    </div>

    <div class="post-sidebar-meta">
      {note.data.tags && note.data.tags.length > 0 && (
        <div class="sidebar-block">
          <p class="sidebar-label">Tags</p>
          <div class="tag-list">
            {note.data.tags.map(t => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </div>
      )}

      {note.data.related && note.data.related.length > 0 && (
        <div class="sidebar-block">
          <p class="sidebar-label">Related</p>
          <div class="tag-list">
            {note.data.related.map(r => (
              <span class="tag tag--muted">{r.replace(/^\[\[|\]\]$/g, '')}</span>
            ))}
          </div>
        </div>
      )}

      {note.data.sources && note.data.sources.length > 0 && (
        <div class="sidebar-block">
          <p class="sidebar-label">Sources</p>
          <ul class="source-list">
            {note.data.sources.map(s => (
              <li><a href={s} class="source-link" target="_blank" rel="noopener">{s}</a></li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .post-main {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-10) var(--space-6) var(--space-24);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-footnote);
    font-weight: var(--weight-medium);
    color: var(--label-tertiary);
    text-decoration: none;
    margin-bottom: var(--space-10);
    letter-spacing: 0.01em;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .back-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* astro-tone signature: colored accent bar above title */
  .post-accent {
    width: 28px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 99px;
    margin-bottom: var(--space-6);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-footnote);
    color: var(--label-tertiary);
    margin-bottom: var(--space-5);
    font-variant-numeric: tabular-nums;
  }

  .meta-tag {
    font-size: var(--text-caption-1);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .meta-dot {
    color: var(--label-quaternary);
  }

  .meta-date {
    color: var(--label-tertiary);
  }

  .post-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0 0 var(--space-5);
    color: var(--label-primary);
  }

  /* astro-tone signature: description with left border */
  .post-description {
    font-size: var(--text-callout);
    color: var(--label-secondary);
    font-weight: 400;
    line-height: 1.64;
    margin: 0;
    max-width: 520px;
    border-left: 2px solid var(--separator);
    padding-left: var(--space-4);
  }

  .post-divider {
    height: 1px;
    background: var(--separator);
    margin: var(--space-8) 0 var(--space-10);
  }

  /* Footer metadata */
  .post-sidebar-meta {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid color-mix(in srgb, var(--separator) 50%, transparent);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .sidebar-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .sidebar-label {
    margin: 0;
    font-size: var(--text-caption-1);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--label-quaternary);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    font-size: var(--text-footnote);
    font-weight: var(--weight-medium);
    color: var(--color-accent);
    background: var(--fill-secondary);
    padding: 0.18em 0.6em;
    border-radius: 99px;
  }

  .tag--muted {
    color: var(--label-secondary);
    background: var(--fill-tertiary);
  }

  .source-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .source-link {
    font-size: var(--text-footnote);
    color: var(--label-secondary);
    word-break: break-all;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 2px;
    transition:
      color var(--duration-fast) var(--ease-out),
      text-decoration-color var(--duration-fast) var(--ease-out);
  }

  .source-link:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
    opacity: 1;
  }

  @media (max-width: 600px) {
    .post-main {
      padding: var(--space-8) var(--space-4) var(--space-16);
    }

    .post-title {
      font-size: 1.75rem;
    }
  }
</style>

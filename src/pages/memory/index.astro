---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const notes = await getCollection('memory');
const sorted = notes.sort((a, b) => String(a.data.name).localeCompare(String(b.data.name)));

// Group by type
const byType = sorted.reduce<Record<string, typeof sorted>>((acc, n) => {
  const t = n.data.type || 'other';
  if (!acc[t]) acc[t] = [];
  acc[t].push(n);
  return acc;
}, {});

const typeOrder = ['user', 'project', 'tech', 'reference', 'feedback', 'other'];
const typeLabels: Record<string, string> = {
  user: 'User',
  project: 'Projects',
  tech: 'Tech',
  reference: 'References',
  feedback: 'Feedback',
  other: 'Other',
};
---

<Layout
  title="Memory — kb.duyet.net"
  description="All memory notes — durable, general, public facts across sessions and tools."
>
  <div class="page-wrap">
    <a href={`${base}/`} class="back-link">← Home</a>

    <header class="page-header">
      <div class="page-accent"></div>
      <h1 class="page-title">Memory</h1>
      <p class="page-desc">
        Durable notes for agents — {notes.length} notes on profile, projects, tech, and workflow.
      </p>
    </header>

    <div class="page-divider"></div>

    {typeOrder.filter(t => byType[t]?.length).map(type => (
      <section class="group">
        <h2 class="group-title">{typeLabels[type] ?? type} <span class="group-count">{byType[type].length}</span></h2>
        <ul class="item-list">
          {byType[type].map(n => (
            <li class="item">
              <a href={`${base}/memory/${n.slug}`} class="item-link">
                <span class="item-title">{n.data.title || n.data.name}</span>
                <span class="item-arrow">→</span>
              </a>
              <span class="item-desc">{n.data.description}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>

<style>
  .page-wrap {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-10) var(--space-6) var(--space-24);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-footnote);
    font-weight: var(--weight-medium);
    color: var(--label-tertiary);
    text-decoration: none;
    margin-bottom: var(--space-10);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .back-link:hover { color: var(--color-accent); opacity: 1; }

  .page-accent {
    width: 28px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 99px;
    margin-bottom: var(--space-6);
  }

  .page-header {
    margin-bottom: var(--space-2);
  }

  .page-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0 0 var(--space-4);
  }

  .page-desc {
    font-size: var(--text-callout);
    color: var(--label-secondary);
    margin: 0;
    line-height: var(--leading-normal);
  }

  .page-divider {
    height: 1px;
    background: var(--separator);
    margin: var(--space-8) 0 var(--space-12);
  }

  .group {
    margin-bottom: var(--space-12);
  }

  .group-title {
    font-size: var(--text-caption-1);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--label-tertiary);
    margin: 0 0 var(--space-4);
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .group-count {
    font-size: var(--text-caption-2);
    color: var(--label-quaternary);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0;
    text-transform: none;
  }

  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .item {
    padding: var(--space-3) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    border-bottom: 1px solid color-mix(in srgb, var(--separator) 30%, transparent);
  }

  .item:first-child {
    border-top: 1px solid color-mix(in srgb, var(--separator) 30%, transparent);
  }

  .item-link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    color: var(--label-primary);
    text-decoration: none;
    font-size: var(--text-callout);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .item-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .item-title {
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    transition: text-decoration-color var(--duration-fast) var(--ease-out);
  }

  .item-link:hover .item-title {
    text-decoration-color: currentColor;
  }

  .item-arrow {
    color: var(--label-quaternary);
    font-size: 0.85em;
    transition:
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .item-link:hover .item-arrow {
    color: var(--color-accent);
    transform: translateX(2px);
  }

  .item-desc {
    font-size: var(--text-footnote);
    color: var(--label-tertiary);
    line-height: var(--leading-normal);
  }

  @media (max-width: 600px) {
    .page-wrap { padding: var(--space-8) var(--space-4) var(--space-16); }
  }
</style>
